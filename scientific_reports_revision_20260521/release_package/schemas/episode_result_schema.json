{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EmbodiedStressBench Episode Result",
  "type": "object",
  "required": [
    "status",
    "task",
    "backend",
    "seed",
    "baseline",
    "query_original",
    "query_used",
    "stressor",
    "level",
    "stress_info",
    "success",
    "failure_type",
    "prediction",
    "execution_debug",
    "target_error_l2",
    "num_detections",
    "runtime_sec"
  ],
  "properties": {
    "status": {"type": "string"},
    "task": {"type": "string"},
    "backend": {"type": "string"},
    "seed": {"type": "integer"},
    "baseline": {"type": "string"},
    "query_original": {"type": "string"},
    "query_used": {"type": "string"},
    "stressor": {"type": "string"},
    "level": {"type": "integer", "minimum": 0},
    "stress_info": {"type": "object"},
    "success": {"type": "boolean"},
    "failure_type": {"type": ["string", "null"]},
    "prediction": {"type": "object"},
    "execution_debug": {"type": "object"},
    "target_error_l2": {"type": ["number", "null"]},
    "num_detections": {"type": "integer"},
    "runtime_sec": {"type": "number"}
  },
  "additionalProperties": true
}
